# Copy to .env on the deployment host and replace every secret with a unique random value.
POSTGRES_DB=hammy
POSTGRES_ADMIN_USER=hammy_admin
POSTGRES_ADMIN_PASSWORD=replace-with-a-random-secret
APP_DB_PASSWORD=replace-with-a-different-random-secret
JWT_SECRET=replace-with-at-least-32-random-bytes
CORS_ORIGINS=
LOG_LEVEL=info
TRUST_PROXY=false
